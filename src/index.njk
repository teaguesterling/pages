---
layout: base.njk
---

{% set badges = projects.badges %}

{# DuckDB Extensions - Authored #}
{% set category = projects.categories.duckdb_extensions %}
<section class="category" id="duckdb-extensions">
  <header class="category-header">
    <h2>{{ category.title }}</h2>
    <p>{{ category.description }}</p>
  </header>

  {% for subKey, subcategory in category.subcategories %}
  <div class="subcategory" id="{{ subKey }}">
    <h3 class="subcategory-title">{{ subcategory.title }}</h3>
    <div class="projects-table">
      <div class="projects-table-header">
        <div class="col-name">Project</div>
        <div class="col-description">Description</div>
        <div class="col-badges">Status</div>
      </div>
      {% for project in subcategory.projects %}
        {% include "project-row.njk" %}
      {% endfor %}
    </div>
  </div>
  {% endfor %}
</section>

